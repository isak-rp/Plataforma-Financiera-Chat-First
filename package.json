{
  "name": "plataforma-financiera-chat-first-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @pfc/frontend dev",
    "build": "pnpm --filter @pfc/frontend build",
    "start": "pnpm --filter @pfc/frontend start",
    "lint": "pnpm --filter @pfc/frontend lint",
    "dev:frontend": "pnpm --filter @pfc/frontend dev",
    "dev:backend": "cd apps/backend && uv run uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:all": "concurrently -n frontend,backend \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "lint:all": "pnpm --filter @pfc/frontend lint && pnpm run check:architecture",
    "test:all": "pnpm run check:architecture && pnpm run check:frontend-services",
    "check:architecture": "bash scripts/check-architecture.sh",
    "check:frontend-services": "bash scripts/check-frontend-services.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
